import pandas as pd
from pathlib import Path

folder = Path(".")

# fetch 30-year fixed mortgage rate from FRED 
url = "https://fred.stlouisfed.org/graph/fredgraph.csv?id=MORTGAGE30US"
mortgage = pd.read_csv(url, parse_dates=["observation_date"])
mortgage.columns = ["date", "rate_30yr_fixed"]

# convert rate to numeric, drop any missing weeks
mortgage["rate_30yr_fixed"] = pd.to_numeric(mortgage["rate_30yr_fixed"], errors="coerce")
mortgage = mortgage.dropna(subset=["rate_30yr_fixed"])

# resample weekly rates to monthly averages
mortgage["year_month"] = mortgage["date"].dt.to_period("M")
mortgage_monthly = mortgage.groupby("year_month")["rate_30yr_fixed"].mean().reset_index()
print("Sample monthly rates:")
print(mortgage_monthly.tail(6).to_string(index=False))

# load both residential datasets from Week 1
sold = pd.read_csv(folder / "combined_sold_residential.csv", low_memory=False)
listings = pd.read_csv(folder / "combined_listings_residential.csv", low_memory=False)

# create year_month key on sold using CloseDate
sold["CloseDate"] = pd.to_datetime(sold["CloseDate"], errors="coerce")
sold["year_month"] = sold["CloseDate"].dt.to_period("M")

# create year_month key on listings using ListingContractDate
listings["ListingContractDate"] = pd.to_datetime(listings["ListingContractDate"], errors="coerce")
listings["year_month"] = listings["ListingContractDate"].dt.to_period("M")

# left merge mortgage rates onto both datasets
sold_with_rates = sold.merge(mortgage_monthly, on="year_month", how="left")
listings_with_rates = listings.merge(mortgage_monthly, on="year_month", how="left")

# validate no null rates after merge
print(f"\nSOLD null rates after merge: {sold_with_rates['rate_30yr_fixed'].isnull().sum()}")
print(f"LISTINGS null rates after merge: {listings_with_rates['rate_30yr_fixed'].isnull().sum()}")

# preview enriched sold dataset
print("\nPreview:")
print(sold_with_rates[["CloseDate", "year_month", "ClosePrice", "rate_30yr_fixed"]].head())

# convert Period to string before saving
sold_with_rates["year_month"] = sold_with_rates["year_month"].astype(str)
listings_with_rates["year_month"] = listings_with_rates["year_month"].astype(str)

# save both enriched datasets as new CSVs
sold_with_rates.to_csv(folder / "sold_with_rates.csv", index=False)
listings_with_rates.to_csv(folder / "listings_with_rates.csv", index=False)

print("\nSaved: sold_with_rates.csv")
print("Saved: listings_with_rates.csv")
print("Week 2-3 Part B Done!")
